# Dokploy environment sample for Bagisto
# Copy this file to .env in the same directory as docker-compose.dokploy.yml
# or set the same variables in the Dokploy application environment UI.

APP_NAME=Bagisto
APP_ENV=production
APP_KEY=base64:YOUR_GENERATED_APP_KEY_HERE
APP_DEBUG=false
APP_URL=https://your-domain.example.com
APP_ADMIN_URL=admin
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_CURRENCY=USD

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bagisto
DB_USERNAME=bagisto
DB_PASSWORD=bagisto
DB_PREFIX=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file
CACHE_PREFIX=

# Elasticsearch
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_USER=null
ELASTICSEARCH_PASS=null
ELASTICSEARCH_API_KEY=null
ELASTICSEARCH_INDEX_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

RESPONSE_CACHE_ENABLED=true

MAIL_MAILER=bagisto-dynamic-smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=shop@example.com
MAIL_FROM_NAME=Shop
ADMIN_MAIL_ADDRESS=admin@example.com
ADMIN_MAIL_NAME=Admin
CONTACT_MAIL_ADDRESS=contact@example.com
CONTACT_MAIL_NAME=Contact

VITE_APP_NAME="${APP_NAME}"
VITE_HOST=localhost
VITE_PORT=5173
