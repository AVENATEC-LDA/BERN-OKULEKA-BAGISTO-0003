{
    "name": "webkul/opengraph-meta",
    "description": "Reusable Open Graph and Twitter meta tag integration for Bagisto shops",
    "type": "package",
    "license": "MIT",
    "authors": [
        {
            "name": "Webkul",
            "email": "support@webkul.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\OpenGraphMeta\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\OpenGraphMeta\\Providers\\OpenGraphMetaServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
